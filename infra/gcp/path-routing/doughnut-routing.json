{
  "backendPathHints": {
    "exactPaths": ["/api", "/install", "/login", "/robots.txt"],
    "pathPrefixes": [
      "/api/",
      "/attachments/",
      "/users/",
      "/oauth2/",
      "/login/oauth2/"
    ],
    "pathPrefixesAllowBare": ["/logout"]
  },
  "mandatoryStaticBucketProbes": [
    "/",
    "/index.html",
    "/assets/.doughnut-path-routing-probe"
  ],
  "localProxy": {
    "spaShellInsteadOfBackendExactPaths": ["/users/identify"]
  },
  "gcpUrlMap": {
    "name": "doughnut-app-service-map",
    "defaultService": "https://www.googleapis.com/compute/v1/projects/carbon-syntax-298809/global/backendServices/doughnut-app-service",
    "staticBackendBucketService": "https://www.googleapis.com/compute/v1/projects/carbon-syntax-298809/global/backendBuckets/doughnut-frontend-backend-bucket",
    "staticPathRules": [
      {
        "paths": ["/assets/*"],
        "pathPrefixRewrite": "/frontend/__FRONTEND_GITHUB_SHA__/assets/"
      },
      {
        "paths": ["/index.html"],
        "pathPrefixRewrite": "/frontend/__FRONTEND_GITHUB_SHA__/index.html"
      },
      {
        "paths": ["/"],
        "pathPrefixRewrite": "/frontend/__FRONTEND_GITHUB_SHA__/index.html"
      },
      {
        "paths": ["/odd-e.ico"],
        "pathPrefixRewrite": "/frontend/__FRONTEND_GITHUB_SHA__/odd-e.ico"
      },
      {
        "paths": ["/odd-e.png"],
        "pathPrefixRewrite": "/frontend/__FRONTEND_GITHUB_SHA__/odd-e.png"
      },
      {
        "paths": ["/mcp-server.bundle.mjs"],
        "pathPrefixRewrite": "/frontend/__FRONTEND_GITHUB_SHA__/mcp-server.bundle.mjs"
      },
      {
        "paths": ["/doughnut-cli-latest/*"],
        "pathPrefixRewrite": "/doughnut-cli-latest/"
      }
    ]
  }
}
