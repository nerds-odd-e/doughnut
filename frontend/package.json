{
  "name": "doughnut-frontend",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.13",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "syncpack fix",
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build --emptyOutDir",
    "serve": "vite preview",
    "lint": "biome check . && vue-tsc --noEmit",
    "format": "biome check --write . && vue-tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "test:ui": "vitest run --browser",
    "test:watch": "vitest --browser --ui",
    "pretest": "node scripts/generateStoryList.mjs && playwright install chromium",
    "test": "CI=true vitest run --browser"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "mini-debounce": "^1.0.8",
    "quill": "npm:@dotwee/quill@2.0.7",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "vue-content-loader": "2.0.1",
    "vue-toastification": "2.0.0-rc.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/vue3": "10.3.3",
    "@storybook/vue3-vite": "10.3.3",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "25.5.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/compiler-core": "3.5.31",
    "@vue/server-renderer": "^3.5.31",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "^10.4.27",
    "daisyui": "4.12.24",
    "doughnut-test-fixtures": "workspace:*",
    "es-toolkit": "^1.45.1",
    "esbuild": "0.27.4",
    "gsap": "^3.14.2",
    "marked": "^17.0.5",
    "optionator": "^0.9.4",
    "playwright": "^1.58.2",
    "postcss": "8.5.8",
    "postcss-load-config": "6.0.1",
    "sass": "1.98.0",
    "storybook": "10.3.3",
    "tailwindcss": "3.4.19",
    "terser": "^5.46.1",
    "typescript": "6.0.2",
    "unimport": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "unplugin-vue-inspector": "^2.4.0",
    "vite": "8.0.3",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "4.1.2",
    "vitest-browser-vue": "^2.1.0",
    "vitest-dom": "^0.1.1",
    "vitest-fetch-mock": "^0.4.5",
    "vue": "3.5.31",
    "vue-router": "5.0.4",
    "vue-tsc": "3.2.6"
  },
  "overrides": {
    "quill": "npm:@dotwee/quill@2.0.7"
  }
}
