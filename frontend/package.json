{
  "name": "doughnut-frontend",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.16",
    "pnpm": ">=11.5.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "syncpack fix",
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build --emptyOutDir",
    "serve": "vite preview",
    "lint": "biome check . && vue-tsc --noEmit",
    "format": "biome check --write . && vue-tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "test:ui": "vitest run --browser=chromium",
    "test:watch": "vitest --browser=chromium --ui",
    "pretest": "node scripts/generateStoryList.mjs && playwright install chromium",
    "test": "CI=true vitest run --browser=chromium"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "epubjs": "^0.3.93",
    "file-saver": "^2.0.5",
    "mini-debounce": "^1.0.8",
    "pdfjs-dist": "5.7.284",
    "quill": "npm:@dotwee/quill@2.0.9",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "vue-content-loader": "2.0.1",
    "vue-toastification": "2.0.0-rc.5",
    "yaml": ">=2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/vue3": "10.4.1",
    "@storybook/vue3-vite": "10.4.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "25.9.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/ui": "4.1.8",
    "@vue/compiler-core": "3.5.35",
    "@vue/server-renderer": "^3.5.35",
    "@vue/test-utils": "2.4.10",
    "daisyui": "5.5.20",
    "doughnut-test-fixtures": "workspace:*",
    "es-toolkit": "^1.47.0",
    "esbuild": "0.28.0",
    "gsap": "^3.15.0",
    "marked": "^18.0.4",
    "optionator": "^0.9.4",
    "playwright": "^1.60.0",
    "sass": "1.100.0",
    "storybook": "10.4.1",
    "tailwindcss": "4.3.0",
    "terser": "^5.48.0",
    "typescript": "6.0.3",
    "unimport": "^6.3.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-inspector": "^3.0.0",
    "vite": "8.0.16",
    "vite-plugin-checker": "^0.14.1",
    "vitest": "4.1.8",
    "vitest-browser-vue": "^2.1.0",
    "vitest-dom": "^0.1.1",
    "vitest-fetch-mock": "^0.4.5",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "vue-tsc": "3.3.3"
  },
  "overrides": {
    "quill": "npm:@dotwee/quill@2.0.9"
  }
}
