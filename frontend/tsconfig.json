{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": [
      "vite/client",
      "vitest/globals",
      "vitest-dom/extend-expect",
      "node",
      "es-toolkit"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"],
      "@generated/doughnut-backend-api": ["../packages/generated/doughnut-backend-api"],
      "@generated/doughnut-backend-api/*": ["../packages/generated/doughnut-backend-api/*"],
      "@generated/*": ["../packages/generated/doughnut-backend-api/*"],
      "@/generated/*": ["../packages/generated/doughnut-backend-api/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "preserve",
    "rootDir": ".."
  },
  "compileOnSave": true,
  "typeAcquisition": {
    "enable": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "tests/**/*.ts",
    "tests/**/*.d.ts",
    "postcss.config.ts",
    "tailwind.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public",
    "/tests//*"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
