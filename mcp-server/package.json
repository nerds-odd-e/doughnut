{
  "name": "doughnut-mcp-server",
  "version": "0.1.0",
  "description": "A Model Context Protocol server for doughnut",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "syncpack fix",
    "bundle": "pnpm exec esbuild src/index.ts --bundle --platform=node --outfile=./dist/mcp-server.bundle.mjs --format=esm --external:@modelcontextprotocol/sdk --external:express --external:express-rate-limit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "format": "biome check --write src/"
  },
  "dependencies": {
    "doughnut-api": "workspace:*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "25.6.0",
    "doughnut-test-fixtures": "workspace:*",
    "esbuild": "0.28.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "zod": "^4.4.2"
  }
}
